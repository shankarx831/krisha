<Application
    x:Class="KrishaSpoke.Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2000/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2000/xaml"
    ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Modern sleek system tray application styling resources -->
        <ResourceDictionary>
            <SolidColorBrush x:Key="WindowBgBrush" Color="#121212"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#1C1C1E"/>
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#007AFF"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8E93"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#2C2C2E"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
